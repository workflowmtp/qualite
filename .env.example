# ===== PostgreSQL =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qcpilot
DB_USER=postgres
DB_PASSWORD=password

# Prisma (construisez DATABASE_URL a partir des params ci-dessus)
DATABASE_URL="postgresql://postgres:password@localhost:5432/qcpilot?schema=public"

# ===== JWT =====
JWT_SECRET=qcpilot_secret_key_change_in_production_2024

# ===== N8N AI Agent =====
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id
N8N_BASIC_USER=your-email@example.com
N8N_BASIC_PASS=your-password

# ===== App =====
NEXT_PUBLIC_APP_NAME=QC Pilot
